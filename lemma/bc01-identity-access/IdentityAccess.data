context IdentityAccess {

    enum AccountStatus {
        ACTIVE,
        INACTIVE,
        LOCKED
    }

    collection Permissions { string }
    collection RoleNames { string }

    // @Table(name = "roles")
    structure Role<entity> {
        // @GeneratedValue(strategy = GenerationType.IDENTITY)
        long id<identifier>,
        // @Column(nullable = false, unique = true, length = 50)
        string name,
        // @ElementCollection(fetch = FetchType.EAGER)
        Permissions permissions
    }

    collection Roles { Role r }

    // @Table(name = "user_accounts")
    structure UserAccount<aggregate, entity> {
        // @GeneratedValue(strategy = GenerationType.IDENTITY)
        long id<identifier>,
        // @Column(nullable = false, unique = true, length = 60)
        string username,
        // @Column(nullable = false, unique = true, length = 120)
        string email,
        // @Column(nullable = false)
        string passwordHash,
        // @Column
        string firstName,
        // @Column
        string lastName,
        // @Column
        string phoneNumber,
        // @Column
        date dateOfBirth,
        // @Enumerated(EnumType.STRING) @Column(nullable = false, length = 20)
        AccountStatus status,
        // @ManyToMany(fetch = FetchType.EAGER)
        Roles roles<part>,

        procedure updateProfile(string username, string email),
        procedure assignRole(Role role),
        procedure revokeRole(Role role)
    }

    structure UserAccountRepository<repository> {
        function UserAccount findByUsername(string username),
        function UserAccount findByEmail(string email)
    }

    structure RoleRepository<repository> {
        function Role findByName(string name)
    }

    structure IdentityAccessService<applicationService> {
        function UserAccount register(string username, string email, string plainPassword,
            string firstName, string lastName, string phoneNumber, date dateOfBirth),
        function UserAccount updateUser(long userId, string username, string email),
        function UserAccount deactivateUser(long userId),
        function UserAccount assignRole(long userId, string roleName),
        function AuthResponse authenticate(string username, string plainPassword),
        function boolean hasPermission(long userId, string permission)
    }

    // Returned by GET /api/auth/validate — used by BC-03 to resolve the requesting user
    structure PrincipalDto<valueObject> {
        immutable long id,
        immutable string username,
        immutable date dateOfBirth,
        immutable Permissions permissions
    }

    structure RegisterUserRequest<valueObject> {
        immutable string username,
        immutable string email,
        immutable string password,
        immutable string firstName,
        immutable string lastName,
        immutable string phoneNumber,
        immutable date dateOfBirth
    }

    structure UpdateUserRequest<valueObject> {
        immutable string username,
        immutable string email
    }

    structure RoleAssignmentRequest<valueObject> {
        immutable string roleName
    }

    structure AuthRequest<valueObject> {
        immutable string username,
        immutable string password
    }

    structure AuthResponse<valueObject> {
        immutable long userId,
        immutable string username,
        immutable Permissions permissions,
        immutable string tokenType
    }

    structure UserResponse<valueObject> {
        immutable long id,
        immutable string username,
        immutable string email,
        immutable string firstName,
        immutable string lastName,
        immutable string phoneNumber,
        immutable date dateOfBirth,
        immutable AccountStatus status,
        immutable RoleNames roles
    }

    collection UserResponses { UserResponse u }

    structure PermissionCheckResponse<valueObject> {
        immutable long userId,
        immutable string permission,
        immutable boolean granted
    }

    structure BookingIdentityCheckResponse<valueObject> {
        immutable boolean verified,
        immutable string reason
    }

    structure PaymentEligibilityResponse<valueObject> {
        immutable long userId,
        immutable boolean eligible,
        immutable string status
    }

    structure ProviderAccessResponse<valueObject> {
        immutable long userId,
        immutable boolean canAccess,
        immutable string status
    }

    structure VehicleInfo<valueObject> {
        immutable long id,
        immutable string type,
        immutable string description,
        immutable string status,
        immutable double pricePerUnit,
        immutable string billingModel,
        immutable int maxPersons
    }

    collection VehicleInfos { VehicleInfo v }

    structure BookingInfo<valueObject> {
        immutable long id,
        immutable long vehicleId,
        immutable string username,
        immutable string status
    }

    collection BookingInfos { BookingInfo b }

    structure VehicleBookingRequest<valueObject> {
        immutable long vehicleId,
        immutable string username
    }
}
